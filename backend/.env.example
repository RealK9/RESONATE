# RESONATE — Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic Claude API Key (for AI-powered track analysis)
ANTHROPIC_API_KEY=

# Cyanite.ai API Key (optional — for advanced audio AI analysis)
CYANITE_API_KEY=

# Cloudflare R2 Storage (dataset + model storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resonate-data

# Spotify API (chart enrichment)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
